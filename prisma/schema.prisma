// Prisma schema for FD-Management.
//
// Single-file SQLite database — backup is a copy of the file (see
// docs/tech_stack_architecture_sketch.md §3, §6). The schema doubles as readable domain
// documentation; the distribution and attendance models arrive in later sessions.
//
// One rule this file cannot state on its own: **at most one non-archived customer may hold a given
// customer number.** Prisma has no syntax for a partial (filtered) unique index, so the statement
// lives at the end of prisma/migrations/*_init/migration.sql, written by hand. Regenerating the
// migration drops it — re-add it, or the slot rule is enforced by application code alone.
//
// Money is always an `Int` of whole cents. SQLite has no decimal type and a float would round a
// price away, so `Float` and `Decimal` appear nowhere in this file.
//
// Note: the walking skeleton uses Prisma's native SQLite provider. Wiring the `better-sqlite3`
// driver adapter (named in the stack doc) is deferred until the database grows beyond settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// One immutable set of the policy values FD can change without a deploy: the customer quota, the
/// portions per head, the price per head and the week-cycle anchor.
///
/// Versions are **append-only**. A distribution record stores only a `paid` flag and never an
/// amount, so the sole way to answer "what did that customer owe last March" is to resolve the
/// version that was in force then (tasks/prd-us-14-configure-business-rules.md, FR-1).
model SettingsVersion {
  id Int @id @default(autoincrement())

  /// The instant these values took over — stamped from the clock when staff saved them, never a
  /// date they pick: a change applies immediately. Deliberately **not** unique; two saves in the
  /// same millisecond are a concurrency accident, not a business error, and the later row wins.
  recordedAt DateTime

  /// The maximum number of customer slots FD hands out.
  quotaN             Int
  /// Food portions allowed per grown-up (13 and older) and per child.
  portionsPerGrownUp Int
  portionsPerChild   Int

  /// The known week of the two-week cycle everything else is counted from, e.g. `2026-W02`, and the
  /// group that collected in it (`RED` or `BLUE`). SQLite has no enum type, so the colour is a
  /// string the domain validates on the way in and out.
  weekAnchorIsoWeek String
  weekAnchorColour  String

  /// Distribution day as an ISO weekday, Monday = 1 … Sunday = 7.
  distributionWeekday Int

  /// What one grown-up and one child each pay, in whole euro cents. FD charges per head, so what a
  /// household owes is derived — `grownUps × pricePerGrownUpCents + children × pricePerChildCents`
  /// — and never stored on this row.
  pricePerGrownUpCents Int
  pricePerChildCents   Int

  @@index([recordedAt])
}

/// A household FD serves.
///
/// `id` is the surrogate key and the **only identity** there is. `customerNumber` is a *slot*: it is
/// what staff and the customer's card say, but an archived household releases it and the next
/// registration fills the gap (tasks/prd-us-01-register-customer.md §US-01.2). Confusing the two is
/// the mistake the Excel sheet made, so every foreign key in this file targets `id` and never
/// `customerNumber`.
///
/// **There is deliberately no `grownUps` and no `children` column.** Both are derived from the
/// household's birthdates wherever they are needed (`src/domain/customer/householdComposition.ts`);
/// stored, they would drift with every birthday — which is exactly what they did in the sheet.
///
/// SQLite has no enum type, so `group` and `status` are strings the domain validates on the way in.
model Customer {
  id Int @id @default(autoincrement())

  /// The slot this household holds, 1..`quotaN`. Not unique on its own — see the partial unique
  /// index added by hand in the migration, which exempts archived rows.
  customerNumber Int

  firstName String
  lastName  String
  birthDate DateTime

  /// The address in flat fields, never a formatted blob: FD sorts and searches by them.
  street      String
  houseNumber String
  zip         String
  city        String

  /// The balancing group, `RED` or `BLUE` — which week of the two-week cycle they collect in.
  group String

  /// `ACTIVE`, `BLOCKED` or `ARCHIVED`. A blocked household is turned away at the counter but still
  /// holds its slot; only archiving releases it. Customer data is never hard-deleted (US-10, US-11).
  status String

  /// How many certificate reminders have gone out (US-06).
  reminderCount Int @default(0)

  /// A free remark, or the empty string. Most households need none.
  notes String @default("")

  householdMembers HouseholdMember[]
  certificates     Certificate[]
  cards            Card[]
  distributions    DistributionRecord[]
  reminderLogs     ReminderLog[]

  @@index([customerNumber])
  @@index([status])
}

/// One person living in the household, the registered customer included.
///
/// Only a name and a birthdate: the birthdate is what every rule that counts heads reads, and no
/// count is stored anywhere.
model HouseholdMember {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  birthDate DateTime

  @@index([customerId])
}

/// The proof of need that entitles a household to shop, e.g. a Jobcenter notice.
///
/// Rows are **appended, never overwritten**: a renewal stacks a new row rather than editing the
/// dates, so the history of renewals stays readable (US-06.3, FR-8). The certificate *on file* is
/// the latest by `recordedAt` — the counter only ever reads that one, but the trail behind it says
/// when each renewal was brought.
model Certificate {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /// What kind of notice it is, as staff typed it.
  type String

  /// The day it stops entitling the household. What the reminder in US-06 counts down to.
  validUntil DateTime

  /// The instant this certificate was recorded, from the injected clock — the registration for the
  /// first row, the renewal for every later one. What "latest" is decided by.
  recordedAt DateTime

  @@index([customerId, recordedAt])
}

/// A shopping card handed to a customer.
///
/// `index` counts from 1 for the card issued with the registration; a reissue after a loss takes the
/// next index (US-09), which is what makes an old card recognisable at the counter. The card number
/// staff read out is derived from the customer number and this index, never stored.
model Card {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  index    Int
  issuedAt DateTime

  /// Why this card was handed over: `FIRST_ISSUE`, `LOST`, `STALE_COUNTS` or `OTHER`. SQLite has no
  /// enum type, so the word is a string the domain validates on the way in and out. It is the one
  /// thing about a superseded card that its index cannot say — why the household needed another one.
  reason String

  /// The rule behind "exactly one valid card" (US-02, FR-3): validity is *being* the highest index,
  /// so two cards sharing one would leave no current card at all. This constraint, not the
  /// application, is the final authority on whether an index was still free when the write landed.
  @@unique([customerId, index])
}

/// One hand-out that actually happened: a customer showed up on a distribution day, paid or did not,
/// and owed the price their household drew under the policy in force then (US-05, FR-1).
///
/// **Records outlive their customer.** There is deliberately no `onDelete: Cascade` on the relation:
/// archiving is a status change, not a delete, and the distribution history must survive it — a report
/// of who collected last March cannot depend on the household still being on the register (US-10,
/// US-11). Customer data is never hard-deleted anyway, so the foreign key only ever points at a row
/// that is still there.
///
/// The once-per-distribution-day rule (FR-5) lives in the domain (`attendance.canRecord`), but the
/// database is its final authority: `dayKey` is a normalised Europe/Berlin calendar-day string
/// (`YYYY-MM-DD`, filled by `berlinDayKey` so it matches the domain rule exactly), and the unique
/// `(customerId, dayKey)` index means a second hand-out on the same day cannot be written even if two
/// requests race past the use case's guard. The raw `date` instant is kept alongside it for the
/// no-show query (US-10) and for display.
model DistributionRecord {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  /// The instant the hand-out was recorded, from the injected clock. Its Berlin calendar day is
  /// `dayKey`; both are stored so the once-per-day constraint never has to reinterpret the instant.
  date DateTime

  /// The Europe/Berlin calendar day of `date` as `YYYY-MM-DD`. Not derivable in SQLite (no timezone
  /// arithmetic), so it is written by the domain's `berlinDayKey` and the unique index below rests on
  /// it. Never a UTC or naive date — see the comment on `src/domain/distribution/attendance.ts`.
  dayKey String

  /// Whether the customer showed up. Always true today — a no-show writes no record at all (FR-6).
  showedUp Boolean

  /// Whether they paid; a flag, never an amount.
  paid Boolean

  /// What the household owed under the policy in force on `date`, in whole euro cents. This is
  /// **deliberate redundancy** alongside the settings history (PRD §6): the price could be re-derived
  /// by resolving the version in force then, but capturing it makes a record self-describing so later
  /// reporting can price a past distribution with a single-table read. It is not to be "cleaned up".
  priceCents Int

  @@unique([customerId, dayKey])
  @@index([date])
  @@index([customerId, date])
}

/// One logged certificate reminder — a day of the documented trail an expired certificate starts at
/// the counter (US-06).
///
/// Entries are appended, never amended: a reminder that was given stays given, and a renewed
/// certificate resets the customer's *count*, not this log. `resultingCount` repeats the count as it
/// stood after the entry, so the trail is readable on its own without replaying it.
///
/// The once-per-day rule lives in the use case (`recordReminder`), but the unique
/// `(customerId, loggedOn)` index below is its final authority: a second reminder on the same day
/// cannot be written even if two requests race past the guard (US-06.3). Like `DistributionRecord`,
/// there is deliberately no `onDelete: Cascade` — the trail outlives status changes, and customer
/// data is never hard-deleted anyway.
model ReminderLog {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  /// The Europe/Berlin calendar day the reminder was given, as `YYYY-MM-DD`. Written by the domain's
  /// `berlinDayKey` — the same notion of "the same day" the attendance rule uses — and never a UTC
  /// or naive date, so the constraint and the guard cannot drift to two notions of "today".
  loggedOn String

  /// The customer's reminder count after this entry.
  resultingCount Int

  @@unique([customerId, loggedOn])
}

/// One append-only record of a state change: *what* changed, *when* and *why* — never *who*.
///
/// FD has ruled out login, so the system cannot tell its three or four staff apart and there is
/// deliberately no actor column (docs/tech_stack_architecture_sketch.md §5.2). With no login the log
/// is the only accountability the system has, so rows are never amended or deleted.
model AuditEntry {
  id Int @id @default(autoincrement())

  /// A stable, machine-readable event name such as `settings.updated`.
  what String

  /// The fields the change touched, comma-separated: SQLite has no array type, and the list is
  /// only ever read back for display.
  changedFields String

  /// When the change happened, read from the injected clock rather than the database.
  when DateTime

  /// The reason a human gave, or empty when none was asked for. A settings edit is self-explanatory
  /// from `changedFields`; the changes that turn on a judgement (block, archive) require one.
  why String

  @@index([when])
}
