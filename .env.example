# Copy to `.env` and adjust as needed. `.env` itself is git-ignored.

# SQLite database file. The `file:` path is resolved by Prisma relative to prisma/schema.prisma,
# so `../data/...` places the database in the repo-root `data/` directory.
# That file is the entire backup unit — see docs/tech_stack_architecture_sketch.md §6.
DATABASE_URL="file:../data/fd.db"
